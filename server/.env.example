APP_NAME=Symtext CMS API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_EXPIRE_HOURS=24
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Symtext <noreply@symtext.com>
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/agentic-cms

# Alibaba Cloud OSS
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
OSS_UPLOAD_DIR=uploads
OSS_SIGNED_URL_EXPIRES_SECONDS=600
OSS_MAX_UPLOAD_BYTES=104857600

# Huawei Cloud OBS (for provider selection module)
HUAWEI_OSS_ENDPOINT=
HUAWEI_OSS_BUCKET_NAME=
HUAWEI_OSS_ACCESS_KEY_ID=
HUAWEI_OSS_ACCESS_KEY_SECRET=
HUAWEI_OSS_PUBLIC_BASE_URL=

# AWS S3 (for provider selection module)
AWS_OSS_REGION=
AWS_OSS_BUCKET_NAME=
AWS_OSS_ACCESS_KEY_ID=
AWS_OSS_ACCESS_KEY_SECRET=
AWS_OSS_PUBLIC_BASE_URL=

# LLM providers (for AI configuration module)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# Celery + Redis (local async worker)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_DEFAULT_QUEUE=symtext-agent-tasks
